{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/steam/search.js": {
      "maxDuration": 30
    },
    "api/steam/priceoverview.js": {
      "maxDuration": 30
    },
    "api/wiki/catalog.js": {
      "maxDuration": 60
    }
  }
}
